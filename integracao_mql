        vid_totals[aid]['vv'] += somar_actions(actions, {'video_view'})
        vid_totals[aid]['imp'] += int(r.get('impressions', 0))

    log(f'  {len(rows)} linhas (ad x dia), {len(vid_totals)} ads com totais de video')
    return rows, vid_totals

# ========== 6. MQL (Google Sheets) ==========
def fetch_mqls():
    """Le MQLs da planilha publica. Col A = data dd/mm/yyyy, col F = MQLs (int).
    Retorna [{'date': 'YYYY-MM-DD', 'mqls': N}, ...]."""
    log('Buscando MQLs da planilha Google...')
    url = f'https://docs.google.com/spreadsheets/d/{GOOGLE_SHEET_ID}/export?format=csv&gid={GOOGLE_SHEET_GID}'
    try:
        r = requests.get(url, timeout=30)
    except requests.RequestException as e:
        log(f'  ERRO rede: {e}'); return []
    if r.status_code != 200:
        snippet = (r.text or '')[:150].replace('\n', ' ')
        log(f'  ERRO HTTP {r.status_code}: {snippet!r}')
        log('  Confira se a planilha esta com "Qualquer pessoa com o link: Leitor"')
        return []
    import csv, io
    rows = []
    reader = csv.reader(io.StringIO(r.text))
    next(reader, None)  # pula cabecalho
    for row in reader:
        if len(row) < 6: continue
        date_raw = (row[0] or '').strip()
        mql_raw = (row[5] or '').strip()
        if not date_raw or not mql_raw: continue
        try:
            d, m, y = date_raw.split('/')
            iso_date = f'{y}-{m.zfill(2)}-{d.zfill(2)}'
        except ValueError:
            continue
        try:
            mql_val = int(float(mql_raw.replace('.', '').replace(',', '.')))
        except ValueError:
            continue
        rows.append({'date': iso_date, 'mqls': mql_val})
    rows.sort(key=lambda x: x['date'])
    log(f'  {len(rows)} dias com MQL')
    return rows

# ========== INJECAO ==========
def replace_var(html, varname, value):
    js = json.dumps(value, ensure_ascii=False, separators=(',',':'))
    pattern = rf'var {varname} = .*?; /\*END_{varname}\*/'
    new_content = f'var {varname} = {js}; /*END_{varname}*/'
    if re.search(pattern, html, flags=re.DOTALL):
        # IMPORTANTE: usa funcao no replacement para NAO interpretar \r \n etc
        return re.sub(pattern, lambda m: new_content, html, flags=re.DOTALL)
    log(f'  AVISO: marker END_{varname} nao encontrado, var nao substituida')
    return html

def update_timestamp(html):
    now = datetime.now().strftime('%d/%m %H:%M')
    return re.sub(r'Atualizado [^<]*', f'Atualizado {now}', html)

