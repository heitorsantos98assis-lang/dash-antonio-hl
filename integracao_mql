    if camp_daily: html = replace_var(html, 'CAMPAIGNS_DAILY', camp_daily); any_data = True
    if ad_meta: html = replace_var(html, 'ADS_META', ad_meta); any_data = True
    if ad_daily: html = replace_var(html, 'ADS_DAILY', ad_daily); any_data = True
    if ad_vid: html = replace_var(html, 'ADS_VIDEO_TOTALS', ad_vid); any_data = True
    # MQLs sao opcionais (planilha externa). Sempre injeta, ate quando lista vazia,
    # pra zerar dados antigos se a planilha sumir/quebrar.
    html = replace_var(html, 'MQL_DAILY', mqls)

    if not any_data:
        log('Nenhum dado obtido da Meta API — abortando sem mexer no HTML.')
        sys.exit(1)

    html = update_timestamp(html)

    with open(BI_PATH + '.bak', 'w', encoding='utf-8') as f:
        f.write(html)
    with open(BI_PATH, 'w', encoding='utf-8') as f:
